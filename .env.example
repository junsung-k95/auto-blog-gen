# ============================================================
# OpenAI (필수 — Whisper STT + GPT-4o 사용 시)
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# Anthropic Claude (Claude 모드 사용 시)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# 네이버 블로그 XML-RPC 설정
# 블로그 관리 > 플러그인/연동 관리 > 글쓰기 API 설정에서 확인
# ============================================================
NAVER_USERNAME=내_네이버_아이디
NAVER_API_PASSWORD=블로그API전용비밀번호
NAVER_BLOG_ID=내_블로그_아이디

# ============================================================
# AI Provider 기본값: "openai" 또는 "claude"
# UI 드롭박스에서 런타임 오버라이드 가능
# ============================================================
AI_PROVIDER=openai

# ============================================================
# 네이버 오픈 API (트렌드 분석 / 제목 최적화용, 선택사항)
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
# 미설정 시 트렌드 데이터 없이 LLM만으로 키워드/제목 최적화
# ============================================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ============================================================
# Slack Webhook (발행 완료 알림, 선택사항)
# https://api.slack.com/messaging/webhooks 에서 발급
# ============================================================
SLACK_WEBHOOK_URL=

# ============================================================
# 서버 설정
# ============================================================
PORT=3000
